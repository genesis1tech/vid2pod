{
  "name": "vid2pod",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/processing/worker.ts",
    "dev:ui": "vite --config src/web/vite.config.ts",
    "build": "tsup",
    "build:ui": "vite build --config src/web/vite.config.ts",
    "start": "node dist/index.js",
    "start:worker": "node dist/processing/worker.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "cli": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/lib-storage": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.1.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.34.0",
    "commander": "^13.1.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "feedsmith": "^2.9.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^144.0.0",
    "jose": "^6.0.0",
    "nanoid": "^5.1.0",
    "pg": "^8.13.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "uuid": "^11.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.13.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
