# Database — REQUIRED
DATABASE_URL=postgresql://vid2pod:vid2pod@localhost:5432/vid2pod

# Redis — REQUIRED
REDIS_URL=redis://localhost:6379

# Object Storage (MinIO/S3) — S3_ENDPOINT, S3_ACCESS_KEY, S3_SECRET_KEY REQUIRED
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=vid2pod-media
S3_PODCAST_BUCKET=vid2pod-podcasts
S3_REGION=us-east-1

# Auth — JWT_SECRET REQUIRED (min 8 characters, use a strong random string in production)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# YouTube Data API (optional)
YOUTUBE_API_KEY=

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# Server
PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development

# Processing
DEFAULT_BITRATE=128000
DEFAULT_TARGET_LUFS=-16
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
