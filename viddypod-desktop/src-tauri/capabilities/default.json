{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for ViddyPod Desktop Agent",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default",
    "shell:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "yt-dlp",
          "sidecar": true,
          "args": true
        },
        {
          "name": "node",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "deep-link:default",
    "autostart:default"
  ]
}
